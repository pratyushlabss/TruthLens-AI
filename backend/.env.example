ENV=development
HOST=0.0.0.0
PORT=8000

# ==================== API KEYS ====================

# OpenAI API Key (for verification and analysis)
OPENAI_API_KEY=

# ==================== DATABASE ====================

DATABASE_URL=sqlite:///./truthlens.db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=truthlens_db
DB_USER=postgres
DB_PASSWORD=

# ==================== AWS (optional) ====================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=truthlens-ai
AWS_REGION=us-east-1

# ==================== APPLICATION CONFIGURATION ====================

CORS_ORIGINS=http://localhost:3000,http://localhost:8000
UPLOAD_DIR=/tmp/truthlens_uploads
MAX_UPLOAD_SIZE_MB=10
REQUEST_TIMEOUT=30
