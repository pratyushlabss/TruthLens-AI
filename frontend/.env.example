# RAG Pipeline API Configuration
# Add this to your .env.local file

# RAG API Backend (Python Flask/FastAPI)
# For local development:
NEXT_PUBLIC_RAG_API_URL=http://127.0.0.1:8000

# For production (replace with your server URL):
# NEXT_PUBLIC_RAG_API_URL=https://api.yourdomain.com/rag

# Other existing environment variables...
# Authentication
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3001
